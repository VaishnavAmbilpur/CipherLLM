{
  "compilerOptions": {
    "target": "es2016",
    "module": "node16",
    "rootDir": "./",
    "moduleResolution": "node16",
    "types": ["node", "jest"],
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "tests/**/*"]
}
